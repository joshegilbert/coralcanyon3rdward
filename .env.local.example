# Supabase
# Copy this file to .env.local and fill in your project values.
# Both NEXT_PUBLIC_ vars are safe to expose in the browser (RLS guards data).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only. Bypasses RLS. NEVER expose in a client component or commit
# the real value. Required for `npm run seed` and any server-side admin work.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Supabase CLI access token (https://supabase.com/dashboard/account/tokens)
# Required for `supabase link` and `supabase db push`. Not used at runtime.
SUPABASE_ACCESS_TOKEN=
